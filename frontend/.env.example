# Frontend System Environment Configuration
# Do not commit the actual .env file, only this template.

# VITE_API_URL should point to the currently running backend API.
# In local development this is usually localhost:3000
# In Vercel, put your Render web-service domain (e.g. https://distri-queue-api.onrender.com)
VITE_API_URL=http://localhost:3000
