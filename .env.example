# Backend System Environment Configuration
# Do not commit the actual .env file, only this template.

# Redis Connection (Required for Local/Prod)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Queue Settings
QUEUE_NAME=main_queue

# Worker Node Specifications
WORKER_CONCURRENCY=5
HEARTBEAT_INTERVAL_MS=5000
HEARTBEAT_TTL_SEC=15
WATCHDOG_INTERVAL_MS=10000
SCHEDULER_INTERVAL_MS=500
BACKOFF_MAX_DELAY_MS=30000
BACKOFF_JITTER_MS=200

# REST API Node Specifications
API_PORT=3000
API_HOST=0.0.0.0
